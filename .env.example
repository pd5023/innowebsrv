# Copy this file to .env and fill in your values
# NEVER commit .env to git

PORT=3000

# PostgreSQL connection string
# Local:  postgresql://postgres:password@localhost:5432/innospecs
# Neon:   postgresql://user:pass@ep-xxx.neon.tech/innospecs?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/innospecs

# Set to 'production' on Render
NODE_ENV=development
